{
  "name": "custom-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal custom gateway focused on OTLP logs over HTTP and gRPC, with in-memory storage and direct forwarding to SigNoz.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "test": "npm run build && node --test test/**/*.test.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@hono/node-server": "^1.14.1",
    "axios": "^1.11.0",
    "hono": "^4.6.17"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
