OTEL_SERVICE_NAME=order-service
SERVICE_VERSION=1.0.0
NODE_ENV=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer change-me
OTEL_RESOURCE_ATTRIBUTES=team=platform,region=local
OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_ENABLE_CONSOLE_CAPTURE=true
OBSERVABILITY_ENABLE_CONSOLE_MIRROR=true
OBSERVABILITY_CONSOLE_MIRROR_IN_DEVELOPMENT_ONLY=true
OBSERVABILITY_REDACT_KEYS=password,token,authorization,cookie,set-cookie
OBSERVABILITY_DISABLE_AUTO_INSTRUMENTATIONS=
OBSERVABILITY_METRICS_INTERVAL=10000
OBSERVABILITY_CAPTURE_UNCAUGHT=true
OBSERVABILITY_CAPTURE_UNHANDLED_REJECTION=true
OBSERVABILITY_EMIT_ONLY_WARN_ERROR_FATAL=false
OBSERVABILITY_SMART_SEVERITY_DETECTION=true
OBSERVABILITY_LOG_DEDUPE_ENABLED=true
OBSERVABILITY_LOG_DEDUPE_WINDOW_MS=3000
OBSERVABILITY_LOG_DEDUPE_LEVELS=warn,error,fatal
OBSERVABILITY_DEBUG=false
OBSERVABILITY_LOG_EXPORT_MAX_QUEUE_SIZE=2048
OBSERVABILITY_LOG_EXPORT_MAX_BATCH_SIZE=512
OBSERVABILITY_LOG_EXPORT_SCHEDULE_DELAY_MS=200
OBSERVABILITY_LOG_EXPORT_TIMEOUT_MS=30000
OBSERVABILITY_LOGGER_NAME=application
OBSERVABILITY_FAIL_FAST=false
OBSERVABILITY_SHUTDOWN_TIMEOUT_MS=5000
